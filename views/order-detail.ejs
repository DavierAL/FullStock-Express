<section class="section container">
    <div style="max-width: 800px; margin: 0 auto;">
        <a href="/orders"
            style="display: inline-block; margin-bottom: 1rem; color: var(--muted-foreground); text-decoration: none;">&larr;
            Volver a Mis Pedidos</a>

        <div class="category-header"
            style="text-align: left; display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap;">
            <div>
                <h1 class="category-header__title">Pedido #<%= order.id %>
                </h1>
                <p class="category-header__description">
                    Realizado el <%= new Date(order.createdAt).toLocaleDateString() %>
                </p>
            </div>
            <div
                style="background-color: var(--foreground); color: var(--background); padding: 0.5rem 1rem; border-radius: 999px; font-weight: bold; text-transform: uppercase; font-size: 0.875rem;">
                Estado: <%= order.status %>
            </div>
        </div>

        <div
            style="border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; margin-bottom: 2rem;">
            <h3 style="margin-bottom: 1rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;">Información
                de Envío</h3>
            <p style="margin-bottom: 0.5rem;"><strong>Recibe:</strong>
                <%= order.shippingInfo ? order.shippingInfo.firstName : order.firstName %>
                <%= order.shippingInfo ? order.shippingInfo.lastName : order.lastName %>
            </p>
            <p style="margin-bottom: 0.5rem;"><strong>Dirección:</strong>
                <%= order.shippingInfo ? order.shippingInfo.address : order.address %>, 
                <%= order.shippingInfo ? order.shippingInfo.city : order.city %>, 
                <%= order.shippingInfo ? order.shippingInfo.region : order.region %>
            </p>
            <p style="margin-bottom: 0;"><strong>Contacto:</strong>
                <%= order.shippingInfo ? order.shippingInfo.email : order.email %> | 
                <%= order.shippingInfo ? order.shippingInfo.phone : order.phone %>
            </p>
        </div>

        <h3 style="margin-bottom: 1rem;">Artículos comprados</h3>
        <div style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem;">
            <% order.items.forEach(item=> { %>
                <div
                    style="display: flex; justify-content: space-between; align-items: center; padding: 1rem; border: 1px solid var(--border); border-radius: var(--radius);">
                    <div style="display: flex; gap: 1rem; align-items: center;">
                        <% if (item.imgSrc) { %>
                            <img src="<%= item.imgSrc %>" alt="<%= item.name %>"
                                style="width: 60px; height: 60px; object-fit: cover; border-radius: var(--radius);">
                            <% } else { %>
                                <div
                                    style="width: 60px; height: 60px; background: var(--muted); border-radius: var(--radius);">
                                </div>
                                <% } %>
                                    <div>
                                        <h4 style="margin: 0;">
                                            <%= item.name %>
                                        </h4>
                                        <p style="color: var(--muted-foreground); margin: 0; font-size: 0.875rem;">
                                            Cantidad: <%= item.quantity %>
                                        </p>
                                    </div>
                    </div>
                    <div style="font-weight: bold;">
                        $<%= ((item.price * item.quantity) / 100).toFixed(2) %>
                    </div>
                </div>
                <% }) %>
        </div>

        <div style="text-align: right; font-size: 1.25rem; margin-bottom: 2rem;">
            <p>Total pagado: <strong>$<%= (order.total / 100).toFixed(2) %></strong></p>
        </div>

        <div style="text-align: center;">
            <form action="/cart/reorder/<%= order.id %>" method="POST">
                <button type="submit" class="button button--primary"
                    style="width: 100%; max-width: 300px; display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;">
                    <img src="/images/icons/cart.svg" alt="" style="width: 20px; filter: invert(1);">
                    Repetir este pedido
                </button>
            </form>
        </div>

    </div>
</section>