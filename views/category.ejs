<section class="category-header">
  <div class="container">
    <div class="category-header__content">
      <h1 class="category-header__title">
        <%= category.name %>
      </h1>
      <p class="category-header__description">
        <%= category.description %>
      </p>
    </div>
  </div>
</section>
<section class="products">
  <div class="container">
    <form action="/category/<%= category.slug %>" method="GET" class="price-filter__form"
      style="display: flex; flex-wrap: wrap; gap: 1.5rem; align-items: flex-end; margin-bottom: 2rem; background: var(--card); padding: 1.5rem; border-radius: 0.5rem; border: 1px solid var(--border);">



      <div style="flex: 1; min-width: 160px;">
        <label for="sortBy"
          style="display: block; font-size: 0.875rem; font-weight: 500; margin-bottom: 0.5rem; color: var(--foreground);">Ordenar
          por</label>
        <select id="sortBy" name="sortBy" class="input-field" style="height: 40px; width: 100%;">
          <option value="recent" <%=sortByQuery==='recent' ? 'selected' : '' %>>Relevancia</option>
          <option value="price-asc" <%=sortByQuery==='price-asc' ? 'selected' : '' %>>Precio: Menor a Mayor</option>
          <option value="price-desc" <%=sortByQuery==='price-desc' ? 'selected' : '' %>>Precio: Mayor a Menor</option>
          <option value="name-asc" <%=sortByQuery==='name-asc' ? 'selected' : '' %>>Nombre: A - Z</option>
          <option value="name-desc" <%=sortByQuery==='name-desc' ? 'selected' : '' %>>Nombre: Z - A</option>
        </select>
      </div>

      <div style="flex: 1; min-width: 120px;">
        <label for="minPrice"
          style="display: block; font-size: 0.875rem; font-weight: 500; margin-bottom: 0.5rem; color: var(--foreground);">Precio
          Min</label>
        <input type="number" name="minPrice" id="minPrice" class="input-field" value="<%= minPrice %>" placeholder="Min"
          style="width: 100%;">
      </div>

      <div style="flex: 1; min-width: 120px;">
        <label for="maxPrice"
          style="display: block; font-size: 0.875rem; font-weight: 500; margin-bottom: 0.5rem; color: var(--foreground);">Precio
          Max</label>
        <input type="number" name="maxPrice" id="maxPrice" class="input-field" value="<%= maxPrice %>" placeholder="Max"
          style="width: 100%;">
      </div>

      <div>
        <button type="submit" class="button button--primary" style="height: 40px; padding: 0 2rem;">Filtrar</button>
      </div>
    </form>

    <div class="products__layout">
      <% if(products.length===0) { %>
        <div class="products__no-stock">
          <h3 class="products__no-stock-title">No hay productos para esta categoría.</h3>
          <p class="products__no-stock-description">Intenta cambiar de categoría o los filtros aplicados.</p>
          <img src="/images/icons/no-stock.svg" alt="">
        </div>
        <% }else { %>
          <div class="products__grid">
            <% for (const product of products) { %>
              <a href="/product/<%= product.id %>" class="product-card">
                <div class="product-card__container">
                  <div class="product-card__image-container">
                    <img src="<%= product.imgSrc %>" alt="<%= product.name %>" class="product-card__image" />
                  </div>
                  <div class="product-card__content">
                    <h2 class="product-card__title">
                      <%= product.name %>
                    </h2>
                    <p class="product-card__description">
                      <%= product.description %>
                    </p>
                    <p class="product-card__price">S/ <%= (product.price / 100).toFixed(2) %>
                    </p>
                  </div>
                </div>
              </a>
              <% } %>
          </div>
          <% } %>
    </div>
  </div>
</section>