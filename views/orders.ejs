<section class="section container">
    <div class="category-header">
        <h1 class="category-header__title">Mis Pedidos</h1>
        <p class="category-header__description">Revisa el historial y estado de tus compras.</p>
    </div>

    <% if (orders.length===0) { %>
        <div style="text-align: center; padding: 4rem 0;">
            <img src="/images/icons/truck.svg" alt="Sin pedidos"
                style="width: 64px; opacity: 0.5; margin-bottom: 1rem;">
            <h2>Aún no has realizado ningún pedido.</h2>
            <a href="/category/polos" class="button button--primary" style="margin-top: 1rem;">Explorar la tienda</a>
        </div>
        <% } else { %>
            <div style="max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; gap: 1rem;">
                <% orders.forEach(order=> { %>
                    <article
                        style="border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
                        <div>
                            <h3 style="margin-bottom: 0.5rem;">Pedido #<%= order.id %>
                            </h3>
                            <p style="color: var(--muted-foreground); font-size: 0.875rem;">
                                Fecha: <%= new Date(order.createdAt).toLocaleDateString() %> <br>
                                    Estado: <strong style="text-transform: capitalize; color: var(--primary);">
                                        <%= order.status %>
                                    </strong>
                            </p>
                        </div>
                        <div style="text-align: right;">
                            <p style="font-weight: bold; font-size: 1.25rem; margin-bottom: 0.5rem;">
                                $<%= (order.total / 100).toFixed(2) %>
                            </p>
                            <a href="/orders/<%= order.id %>" class="button button--outline">Ver detalle</a>
                        </div>
                    </article>
                    <% }) %>
            </div>
            <% } %>
</section>