<section class="container">
    <div class="category-header" style="margin-bottom: 2rem;">
        <h1 class="category-header__title">Mi Cuenta</h1>
        <p class="category-header__description">Actualiza tus datos personales y dirección de envío.</p>
    </div>

    <% if (typeof error !=='undefined' ) { %>
        <div class="error" style="margin-bottom: 2rem; color: red;">
            <p>
                <%= error %>
            </p>
        </div>
        <% } %>

            <div
                style="max-width: 600px; margin: 0 auto 2rem; display: flex; justify-content: space-between; align-items: center; padding: 1.5rem; border: 1px solid var(--border); border-radius: var(--radius); background: var(--card);">
                <div>
                    <h2 style="margin: 0 0 0.25rem 0; font-size: 1.25rem;">Mis Pedidos</h2>
                    <p style="margin: 0; color: var(--muted-foreground); font-size: 0.875rem;">Revisa el estado y el
                        historial de tus compras</p>
                </div>
                <a href="/orders" class="button button--outline"
                    style="display: flex; gap: 0.5rem; align-items: center;">
                    <img src="/images/icons/truck.svg" alt="pedidos" style="width: 20px; filter: grayscale(1);">
                    Ver historial
                </a>
            </div>

            <form action="/profile" method="POST" style="max-width: 600px; margin: 0 auto;">

                <div style="margin-bottom: 1.5rem;">
                    <label for="firstName" style="display: block; margin-bottom: 0.5rem;">Nombre</label>
                    <input type="text" id="firstName" name="firstName" class="input-field"
                        value="<%= user.firstName || '' %>" placeholder="Ej. Davier">
                </div>

                <div style="margin-bottom: 1.5rem;">
                    <label for="lastName" style="display: block; margin-bottom: 0.5rem;">Apellido</label>
                    <input type="text" id="lastName" name="lastName" class="input-field"
                        value="<%= user.lastName || '' %>" placeholder="Ej. Lopez">
                </div>

                <div style="margin-bottom: 1.5rem;">
                    <label for="phone" style="display: block; margin-bottom: 0.5rem;">Teléfono</label>
                    <input type="tel" id="phone" name="phone" class="input-field" value="<%= user.phone || '' %>"
                        placeholder="+51 999 999 999">
                </div>

                <div style="margin-bottom: 2rem;">
                    <label for="address" style="display: block; margin-bottom: 0.5rem;">Dirección de Envío</label>
                    <textarea id="address" name="address" class="input-field" rows="3"
                        placeholder="Av. Siempre Viva 123..."><%= user.address || '' %></textarea>
                </div>

                <button type="submit" class="button button--primary" style="width: 100%; margin-bottom: 4rem;">
                    Guardar Cambios
                </button>
            </form>
</section>