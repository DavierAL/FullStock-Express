<section class="section">
    <div class="container signup">
        <h1 class="signup__title">Crea una cuenta</h1>
        <form class="signup__form" method="post" action="/signup">
            <div class="input-field">
                <label for="email">Correo electrónico</label>
                <input id="email" name="email" type="email" required autocomplete="email" />
            </div>
            <div class="input-field">
                <label for="password">Contraseña</label>
                <input id="password" name="password" type="password" required />
            </div>
            <div class="input-field">
                <label for="confirm-password">Confirma tu contraseña</label>
                <input id="confirm-password" name="confirmPassword" type="password" required />
            </div>
            <button type="submit" class="button button--lg signup__submit">
                Crear cuenta
            </button>
        </form>
        <div class="signup__footer">
            <span class="signup__footer_text"> ¿Ya tienes una cuenta? </span>
            <a href="/login" class="signup__footer_link"> Inicia sesión </a>
        </div>
    </div>
    <% if (locals.error) { %>
        <p class="error">
            <%= locals.error %>
        </p>
        <% } %>
</section>